{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        "coins": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 20"
        }
      }
    },
    "rooms": {
      "$roomId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "players": {
          "$uid": {
            ".write": "$uid === auth.uid || data.parent().parent().child('host').val() === auth.uid"
          }
        },
        "gameState": {
          ".write": "data.parent().child('host').val() === auth.uid || !data.exists()"
        },
        "status": {
          ".write": "data.parent().child('host').val() === auth.uid"
        }
      }
    },
    "leaderboard": {
      ".read":  "auth != null",
      "$uid":   { ".write": "$uid === auth.uid" }
    }
  }
}
